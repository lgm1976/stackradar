# Site base URL. Leave blank to use the free Vercel subdomain default
# (https://stackradar.vercel.app). Set this in Vercel only when you add a
# custom domain later, e.g. https://stackradar.com
NEXT_PUBLIC_SITE_URL=

# Supabase (free tier) — copy to .env.local and fill in
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Affiliate base tracking tag appended to outbound links
NEXT_PUBLIC_AFFILIATE_TAG=stackradar
