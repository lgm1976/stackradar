# Site base URL — MUST match your live Vercel URL so sitemap/robots/canonicals
# point to the right place. e.g. https://stackradar-beta.vercel.app
NEXT_PUBLIC_SITE_URL=

# Google Search Console HTML-tag verification token (the content="..." value).
# Set in Vercel, redeploy, then click Verify in GSC.
NEXT_PUBLIC_GOOGLE_VERIFICATION=

# Supabase (free tier) — copy to .env.local and fill in
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Affiliate base tracking tag appended to outbound links
NEXT_PUBLIC_AFFILIATE_TAG=stackradar
